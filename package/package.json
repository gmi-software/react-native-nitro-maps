{
  "name": "react-native-nitro-maps",
  "version": "1.0.0",
  "description": "High-performance maps for React Native built on Nitro Modules and the New Architecture",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/index.d.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "app.plugin.js",
    "src",
    "lib",
    "plugin/build",
    "nitrogen",
    "ios",
    "android",
    "cpp",
    "nitro.json",
    "react-native-nitro-maps.podspec",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build && bun run build:plugin",
    "clean:plugin": "rm -rf plugin/build",
    "build:plugin": "bun run clean:plugin && tsc --project tsconfig.plugin.json",
    "prepack": "bun run build",
    "test": "jest",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.plugin.json --noEmit",
    "typecheck:provider-types": "tsc --noEmit -p tsconfig.type-tests.json",
    "nitrogen": "nitrogen && bun ./scripts/patch-nitrogen-generated.mjs"
  },
  "expo": {
    "plugin": "./app.plugin.js"
  },
  "keywords": [
    "react-native",
    "maps",
    "nitro",
    "nitro-modules",
    "mapkit",
    "google-maps",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gmi-software/react-native-nitro-maps.git"
  },
  "bugs": {
    "url": "https://github.com/gmi-software/react-native-nitro-maps/issues"
  },
  "homepage": "https://github.com/gmi-software/react-native-nitro-maps#readme",
  "author": "GMI Software",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.78.0",
    "react-native-nitro-modules": ">=0.35.0"
  },
  "devDependencies": {
    "@expo/config-plugins": "~56.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.15",
    "jest": "^29.7.0",
    "nitrogen": "^0.35.9",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.43.0",
    "react-native-nitro-modules": "^0.35.10",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  }
}
